# Feature: Delete Transaction
# ─────────────────────────────────────────────
def delete_transaction() -> None:
    """
    Prompt the user for a transaction ID and remove that record from the CSV.
    """
    transactions = load_transactions()
    if not transactions:
        print_info("No transactions to delete.")
        return
    # Show the full list first so the user can pick an ID
    _print_transaction_table(transactions)
    while True:
        try:
            target_id = int(input(colored("\n  Enter the ID of the transaction to delete: ", Colors.WHITE)))
            break
        except ValueError:
            print(colored("  ✗  Please enter a valid numeric ID.", Colors.RED))
    # Check if the ID exists
    matching = [t for t in transactions if int(t["id"]) == target_id]
    if not matching:
        print_error(f"No transaction found with ID {target_id}.")
        return
    record = matching[0]
    confirm = input(colored(
        f"\n  Delete '{record['description']}' ({format_currency(record['amount'])})? [y/N]: ",
        Colors.YELLOW,
    )).strip().lower()
    if confirm == "y":
        updated = [t for t in transactions if int(t["id"]) != target_id]
        _rewrite_csv(updated)
        print_success(f"Transaction ID {target_id} deleted successfully.")
    else:
        print_info("Deletion cancelled.")
def _rewrite_csv(transactions: list[dict]) -> None:
    """
    Overwrite the CSV file with the provided list of transactions.
    Used after a deletion to re-save the remaining records.
    Args:
        transactions (list[dict]): The updated list of transactions.
    """
    try:
        with open(DATA_FILE, mode="w", newline="", encoding="utf-8") as file:
            writer = csv.DictWriter(file, fieldnames=CSV_HEADERS)
            writer.writeheader()
            for t in transactions:
                writer.writerow(t)
    except IOError as error:
        print_error(f"Could not update data file: {error}")
