# Feature: Add Transaction
# ─────────────────────────────────────────────
def pick_category(categories: list[str]) -> str:
    """
    Display a numbered list of categories and let the user pick one.
    Args:
        categories (list[str]): The list of category options.
    Returns:
        str: The selected category name.
    """
    print(colored("\n  Select a category:", Colors.WHITE))
    for i, category in enumerate(categories, start=1):
        print(colored(f"    {i}. {category}", Colors.CYAN))
    while True:
        try:
            choice = int(input(colored("\n  Enter category number: ", Colors.WHITE)))
            if 1 <= choice <= len(categories):
                return categories[choice - 1]
            print(colored("  ⚠  Please choose a valid number from the list.", Colors.YELLOW))
        except ValueError:
            print(colored("  ✗  Enter a number only.", Colors.RED))
def add_transaction(transaction_type: str) -> None:
    """
    Interactively collect details from the user and save a new transaction.
    Args:
        transaction_type (str): Either 'income' or 'expense'.
    """
    transactions = load_transactions()
    new_id       = get_next_id(transactions)
    type_label   = transaction_type.capitalize()
    print(colored(f"\n  ── Adding New {type_label} ──\n", Colors.BOLD + Colors.GREEN))
    # Choose the relevant category list based on transaction type
    categories = INCOME_CATEGORIES if transaction_type == "income" else EXPENSE_CATEGORIES
    category   = pick_category(categories)
    # Collect remaining details
    description = get_non_empty_string(colored("\n  Description : ", Colors.WHITE))
    amount      = get_valid_float(colored("  Amount (₹)  : ", Colors.WHITE))
    date_str    = get_valid_date(
        colored("  Date (YYYY-MM-DD) [Enter = today]: ", Colors.WHITE)
    )
    # Build the transaction record
    transaction = {
        "id"         : new_id,
        "date"       : date_str,
        "type"       : transaction_type,
        "category"   : category,
        "description": description,
        "amount"     : f"{amount:.2f}",
    }
    save_transaction(transaction)
    print_success(
        f"{type_label} of {format_currency(amount)} added successfully! [ID: {new_id}]"
    )
