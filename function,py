# Feature: Financial Summary
# ─────────────────────────────────────────────
def _calculate_summary(transactions: list[dict]) -> dict:
    """
    Calculate total income, total expenses, and net balance.
    Args:
        transactions (list[dict]): List of transaction records.
    Returns:
        dict: A dictionary with 'income', 'expense', and 'balance' totals.
    """
    total_income  = sum(t["amount"] for t in transactions if t["type"] == "income")
    total_expense = sum(t["amount"] for t in transactions if t["type"] == "expense")
    net_balance   = total_income - total_expense
    return {
        "income" : total_income,
        "expense": total_expense,
        "balance": net_balance,
    }
def view_summary() -> None:
    """Display a complete financial summary with totals and category breakdowns."""
    transactions = load_transactions()
    if not transactions:
        print_info("No transactions found. Add some income or expenses first.")
        return
    summary = _calculate_summary(transactions)
    # ── Overall Summary ──
    print(colored("\n  ── Overall Financial Summary ──\n", Colors.BOLD))
    print_divider()
    print(colored(f"  {'Total Income'  :<25} {format_currency(summary['income']):>12}", Colors.GREEN))
    print(colored(f"  {'Total Expenses':<25} {format_currency(summary['expense']):>12}", Colors.RED))
    print_divider()
    # Show net balance in green (positive) or red (negative)
    balance_color = Colors.GREEN if summary["balance"] >= 0 else Colors.RED
    balance_icon  = "▲" if summary["balance"] >= 0 else "▼"
    print(colored(
        f"  {balance_icon} {'Net Balance':<23} {format_currency(summary['balance']):>12}",
        Colors.BOLD + balance_color,
    ))
    print_divider()
    # ── Expense Breakdown by Category ──
    expense_records = [t for t in transactions if t["type"] == "expense"]
    if expense_records:
        print(colored("\n  ── Expense Breakdown by Category ──\n", Colors.BOLD))
        category_totals: dict[str, float] = {}
        for t in expense_records:
            category_totals[t["category"]] = category_totals.get(t["category"], 0) + t["amount"]
        # Sort categories by amount (highest first)
        sorted_categories = sorted(category_totals.items(), key=lambda x: x[1], reverse=True)
        for cat, total in sorted_categories:
            # Calculate percentage of total expenses
            percentage = (total / summary["expense"] * 100) if summary["expense"] > 0 else 0
            bar        = "█" * int(percentage / 5)  # Simple ASCII bar chart (max 20 chars)
            print(colored(
                f"  {cat:<15} {format_currency(total):>12}  {bar:<20} {percentage:5.1f}%",
                Colors.CYAN,
            ))
    # ── Income Breakdown by Category ──
    income_records = [t for t in transactions if t["type"] == "income"]
    if income_records:
        print(colored("\n  ── Income Breakdown by Category ──\n", Colors.BOLD))
        category_totals = {}
        for t in income_records:
            category_totals[t["category"]] = category_totals.get(t["category"], 0) + t["amount"]
        for cat, total in sorted(category_totals.items(), key=lambda x: x[1], reverse=True):
            percentage = (total / summary["income"] * 100) if summary["income"] > 0 else 0
            bar        = "█" * int(percentage / 5)
            print(colored(
                f"  {cat:<15} {format_currency(total):>12}  {bar:<20} {percentage:5.1f}%",
                Colors.GREEN,
            ))
