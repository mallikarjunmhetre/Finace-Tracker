# Path to the CSV file where all transactions are stored
DATA_FILE = "data/transactions.csv"
# The column headers for the CSV file
CSV_HEADERS = ["id", "date", "type", "category", "description", "amount"]
# Valid transaction types
TRANSACTION_TYPES = ("income", "expense")
# Pre-defined categories for convenience
INCOME_CATEGORIES  = ["Salary", "Freelance", "Investment", "Gift", "Other"]
EXPENSE_CATEGORIES = ["Food", "Transport", "Rent", "Healthcare", "Entertainment",
                      "Shopping", "Education", "Utilities", "Other"]
# ─────────────────────────────────────────────
# File / Data Management
# ─────────────────────────────────────────────
def initialize_data_file() -> None:
    """
    Ensure the data directory and CSV file exist.
    Creates them with header row if they don't exist yet.
    """
    # Create the data/ directory if it doesn't exist
    os.makedirs("data", exist_ok=True)
    # Only write headers if the file is new or empty
    if not os.path.exists(DATA_FILE) or os.path.getsize(DATA_FILE) == 0:
        with open(DATA_FILE, mode="w", newline="", encoding="utf-8") as file:
            writer = csv.DictWriter(file, fieldnames=CSV_HEADERS)
            writer.writeheader()
def load_transactions() -> list[dict]:
    """
    Load all transactions from the CSV file into a list of dictionaries.
    Returns:
        list[dict]: A list of transaction records, each as a dict.
    """
    initialize_data_file()
    transactions = []
    try:
        with open(DATA_FILE, mode="r", newline="", encoding="utf-8") as file:
            reader = csv.DictReader(file)
            for row in reader:
                # Convert amount to float for calculations
                row["amount"] = float(row["amount"])
                transactions.append(row)
    except FileNotFoundError:
        pass  # File doesn't exist yet; return empty list
    except Exception as error:
        print_error(f"Could not load data: {error}")
    return transactions
def save_transaction(transaction: dict) -> None:
    """
    Append a single transaction record to the CSV file.
    Args:
        transaction (dict): A dictionary with keys matching CSV_HEADERS.
    """
    initialize_data_file()
    try:
        with open(DATA_FILE, mode="a", newline="", encoding="utf-8") as file:
            writer = csv.DictWriter(file, fieldnames=CSV_HEADERS)
            writer.writerow(transaction)
    except IOError as error:
        print_error(f"Could not save transaction: {error}")
def get_next_id(transactions: list[dict]) -> int:
    """
    Calculate the next available transaction ID (auto-increment).
    Args:
        transactions (list[dict]): The current list of transactions.
    Returns:
        int: The next unique transaction ID.
    """
    if not transactions:
        return 1
    # Find the maximum existing ID and add 1
    max_id = max(int(t["id"]) for t in transactions)
    return max_id + 1
