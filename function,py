def _print_transaction_table(transactions: list[dict]) -> None:
    """
    Print a formatted table of transactions to the terminal.
    Args:
        transactions (list[dict]): The list of transactions to display.
    """
    if not transactions:
        print_info("No transactions found.")
        return
    # Table column widths
    col_widths = {"id": 4, "date": 12, "type": 9, "category": 14, "description": 22, "amount": 12}
    # Print header row
    header = (
        f"  {'ID':<{col_widths['id']}} "
        f"{'Date':<{col_widths['date']}} "
        f"{'Type':<{col_widths['type']}} "
        f"{'Category':<{col_widths['category']}} "
        f"{'Description':<{col_widths['description']}} "
        f"{'Amount':>{col_widths['amount']}}"
    )
    print(colored(header, Colors.BOLD + Colors.WHITE))
    print_divider()
    # Print each transaction row
    for t in transactions:
        # Choose color based on transaction type
        amount_color = Colors.GREEN if t["type"] == "income" else Colors.RED
        type_color   = Colors.GREEN if t["type"] == "income" else Colors.RED
        type_icon = "▲" if t["type"] == "income" else "▼"
        row = (
            f"  {t['id']:<{col_widths['id']}} "
            f"{t['date']:<{col_widths['date']}} "
            f"{type_icon} {t['type']:<{col_widths['type'] - 2}} "
            f"{t['category']:<{col_widths['category']}} "
            f"{t['description'][:20]:<{col_widths['description']}} "
        )
        print(colored(row, type_color), end="")
        print(colored(f"{format_currency(t['amount']):>{col_widths['amount']}}", amount_color))
    print_divider()
    print(colored(f"  Total records: {len(transactions)}", Colors.CYAN))
def view_all_transactions() -> None:
    """Load and display all saved transactions in a formatted table."""
    transactions = load_transactions()
    print(colored(f"\n  All Transactions ({len(transactions)} records)\n", Colors.BOLD))
    _print_transaction_table(transactions)
def view_transactions_by_type(transaction_type: str) -> None:
    """
    Filter and display transactions by type (income or expense).
    Args:
        transaction_type (str): 'income' or 'expense'.
    """
    all_transactions = load_transactions()
    filtered = [t for t in all_transactions if t["type"] == transaction_type]
    label    = transaction_type.capitalize()
    print(colored(f"\n  {label} Transactions ({len(filtered)} records)\n", Colors.BOLD))
    _print_transaction_table(filtered)
def view_transactions_by_month() -> None:
    """Ask the user for a month/year and display matching transactions."""
    print(colored("\n  Filter by Month", Colors.BOLD))
    while True:
        month_input = input(colored("  Enter month and year (MM-YYYY): ", Colors.WHITE)).strip()
        try:
            # Validate format using strptime
            datetime.strptime(month_input, "%m-%Y")
            break
        except ValueError:
            print(colored("  ✗  Invalid format. Use MM-YYYY (e.g., 07-2025).", Colors.RED))
    month, year = month_input.split("-")
    prefix      = f"{year}-{month.zfill(2)}"  # e.g., "2025-07"
    all_transactions = load_transactions()
    filtered = [t for t in all_transactions if t["date"].startswith(prefix)]
    print(colored(f"\n  Transactions for {month}/{year} ({len(filtered)} records)\n", Colors.BOLD))
    _print_transaction_table(filtered)
