# Feature: Export to Text Report
# ─────────────────────────────────────────────
def export_report() -> None:
    """
    Generate a plain-text financial report and save it to the reports/ folder.
    The report includes all transactions and a financial summary.
    """
    transactions = load_transactions()
    if not transactions:
        print_info("No data to export. Please add transactions first.")
        return
    os.makedirs("reports", exist_ok=True)
    timestamp   = datetime.now().strftime("%Y%m%d_%H%M%S")
    report_file = f"reports/finance_report_{timestamp}.txt"
    summary     = _calculate_summary(transactions)
    try:
        with open(report_file, mode="w", encoding="utf-8") as file:
            file.write("=" * 60 + "\n")
            file.write("       PERSONAL FINANCE TRACKER — REPORT\n")
            file.write(f"       Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
            file.write("=" * 60 + "\n\n")
            # Write all transactions
            file.write("ALL TRANSACTIONS\n")
            file.write("-" * 60 + "\n")
            file.write(f"{'ID':<4} {'Date':<12} {'Type':<10} {'Category':<15} {'Description':<22} {'Amount':>10}\n")
            file.write("-" * 60 + "\n")
            for t in transactions:
                file.write(
                    f"{t['id']:<4} {t['date']:<12} {t['type']:<10} "
                    f"{t['category']:<15} {t['description'][:20]:<22} "
                    f"{format_currency(t['amount']):>10}\n"
                )
            # Write summary
            file.write("\n" + "=" * 60 + "\n")
            file.write("FINANCIAL SUMMARY\n")
            file.write("-" * 60 + "\n")
            file.write(f"{'Total Income'  :<30} {format_currency(summary['income']):>12}\n")
            file.write(f"{'Total Expenses':<30} {format_currency(summary['expense']):>12}\n")
            file.write(f"{'Net Balance'   :<30} {format_currency(summary['balance']):>12}\n")
            file.write("=" * 60 + "\n")
        print_success(f"Report exported successfully → {report_file}")
    except IOError as error:
        print_error(f"Could not write report: {error}")
